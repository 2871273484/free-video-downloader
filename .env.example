# 复制为 .env 后按需修改

# 会员令牌签名密钥（务必改成一长串随机字符）
SECRET_KEY=change-me-please-a-long-random-string

# Cookie（抖音 / B站高清 / 会员内容等平台可能需要，二选一，留空则不用）
# 方式一（推荐，最稳）：浏览器插件（如 "Get cookies.txt LOCALLY"）导出 cookies.txt，填绝对路径
COOKIES_FILE=
# 方式二：从本机浏览器直接读取。Chrome/Edge 运行时会锁库，建议用 firefox
# 可选值：firefox / chrome / edge / chromium / brave / opera / vivaldi
COOKIES_FROM_BROWSER=

# AI（OpenAI 兼容接口，留空则 AI 功能自动降级为提示）
# 兼容 DeepSeek / 通义 / OpenAI 等，填对应的 BASE_URL 与 KEY
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat

# 免费额度
FREE_MAX_HEIGHT=720
FREE_MAX_BATCH=3

# 会员有效期（天）
MEMBER_DAYS=365

# 万能兑换码：可多人重复使用、永不作废，兑换即得完整会员（含 AI）。
# 逗号分隔可配多个。上线正式环境请务必改成别人猜不到的值。
UNIVERSAL_CODES=VIP-FOREVER

# 下载文件保留时长（秒）
FILE_TTL_SECONDS=3600
